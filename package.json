    "astro": "^6.4.2",
    "clsx": "^2.1.1",
    "pagefind": "^1.5.2",
    "reading-time": "^1.5.0",
    "rehype-external-links": "^3.0.0",
    "remark-gfm": "^4.0.0",
    "remark-smartypants": "^2.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cypress/grep": "^6.0.1",
    "@typescript-eslint/parser": "^8.60.0",
    "cypress": "^15.16.0",
    "cypress-test-order-randomizer": "^1.0.0",
    "eslint": "^10.4.1",
