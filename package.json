    "start": "astro dev",
    "test": "npm run build && start-server-and-test preview http://localhost:4321 cy:run"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
