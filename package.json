{
  "name": "alxndr-blog",
  "version": "3.0.0-alpha",
  "scripts": {
    "astro": "astro",
    "build": "astro build && pagefind --site dist",
    "check": "astro check",
    "cy:open": "cypress open",
    "cy:open:dev": "cypress open --expose grepTags=-@requires-build",
    "cy:run": "cypress run",
    "cy:run:dev": "cypress run --expose grepTags=-@requires-build",
    "dev": "astro dev",
    "lint": "eslint src",
