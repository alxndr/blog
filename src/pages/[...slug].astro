---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import { getImage } from 'astro:assets'
import readingTime from 'reading-time'
import BaseLayout from '../layouts/BaseLayout.astro';
import Bio from '../components/Bio.astro';
import { tagToSlug } from '../utils/tagSlug.js';

type Props = {
  post: CollectionEntry<'posts'>
  prevPost: CollectionEntry<'posts'> | null
  nextPost: CollectionEntry<'posts'> | null
}

export async function getStaticPaths() {
	const allPosts = await getCollection('posts')
	const publishedPosts = allPosts
		.filter(p => !p.data.draft)
		.sort((a, b) => new Date(a.data.publishDate).getTime() - new Date(b.data.publishDate).getTime())

	return publishedPosts.map((post, index: number) => ({
		params: { slug: post.data.slug },
		props: {
			post,
			prevPost: index > 0 ? publishedPosts[index - 1] : null,
			nextPost: index < publishedPosts.length - 1 ? publishedPosts[index + 1] : null,
		},
	}));
}

const { post, prevPost, nextPost } = Astro.props
const { title, slug, description, publishDate, tags, thumbnail } = post.data;
const readingTimeEstimate = readingTime(post.body ?? '').text
const permalink = `${Astro.site}${slug}/`;
const { Content } = await render(post)

const thumbnailImage = thumbnail ? await getImage({ src: thumbnail, format: 'jpeg' }) : null
const socialImage = thumbnailImage ? new URL(thumbnailImage.src, Astro.site).href : undefined
---

<BaseLayout title={title} description={description} permalink={permalink} image={socialImage}>
  <div class="container">
    <header>
      <p>{publishDate} ~ {readingTimeEstimate}</p>
      <h1>{title}</h1>
      {tags && tags.length > 0 && (
        <p class="tags">
          {tags.map(tag => (
            <a href={`/tags/${tagToSlug(tag)}/`} class="tag-link" title={`Posts tagged "${tag}"`}>#{tag}</a>
          ))}
        </p>
      )}
      <hr />
    </header>
    <article class="content">
      <Content />
    </article>
    {(prevPost || nextPost) && (
      <nav aria-label="Post navigation" class="post-nav">
        {prevPost
          ? <a href={`/${prevPost.data.slug}/`} rel="prev" class="post-nav-link prev" aria-label={`Previous post: ${prevPost.data.title}`}>
              ← prev
            </a>
          : <span />
        }
        {nextPost &&
          <a href={`/${nextPost.data.slug}/`} rel="next" class="post-nav-link next" aria-label={`Next post: ${nextPost.data.title}`}>
            next →
          </a>
        }
      </nav>
    )}
    <hr />
    <Bio />
  </div>
</BaseLayout>

<style>
  header {
    text-align: center;
  }

  header h1 {
    margin-bottom: 0.7em;
  }

  header p {
    color: var(--text-secondary);
    text-transform: uppercase;
    font-family: var(--font-family-sans);
    font-weight: 600;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em 0.75em;
    justify-content: center;
    text-transform: none;
  }

  header hr {
    min-width: 100px;
    width: 30%;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1em;
    margin-top: 2.5em;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
    max-width: 45%;
    text-decoration: none;
    color: inherit;
  }

  .post-nav-link.next {
    text-align: right;
    margin-left: auto;
  }

  .post-nav-link:hover {
    text-decoration: underline;
  }
</style>
