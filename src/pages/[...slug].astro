---
import { getCollection, render } from 'astro:content'
import readingTime from 'reading-time'
import BaseLayout from '../layouts/BaseLayout.astro';
import Bio from '../components/Bio.astro';
import { tagToSlug } from '../utils/tagSlug.js';

export async function getStaticPaths() {
	const allPosts = await getCollection('posts')
	const publishedPosts = allPosts.filter(p => !p.data.draft)
	return publishedPosts.map(p => ({
		params: { slug: p.data.slug },
		props: { post: p },
	}));
}

const { post } = Astro.props
const { title, slug, description, publishDate, tags } = post.data;
const readingTimeEstimate = readingTime(post.body ?? '').text
const permalink = `${Astro.site}${slug}/`;
const { Content } = await render(post)
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <header>
    <p>{publishDate} ~ {readingTimeEstimate}</p>
    <h1>{title}</h1>
    {tags && tags.length > 0 && (
      <p class="tags">
        {tags.map(tag => (
          <a href={`/tags/${tagToSlug(tag)}/`} class="tag-link" title={`Posts tagged "${tag}"`}>#{tag}</a>
        ))}
      </p>
    )}
    <hr />
  </header>
  <div class="container">
    <article class="content">
      <Content />
    </article>
    <hr />
    <Bio />
  </div>
</BaseLayout>

<style>
  header {
    text-align: center;
  }

  header h1 {
    margin-bottom: 0.7em;
  }

  header p {
    color: var(--text-secondary);
    text-transform: uppercase;
    font-family: var(--font-family-sans);
    font-weight: 600;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em 0.75em;
    justify-content: center;
    text-transform: none;
  }

  header hr {
    min-width: 100px;
    width: 30%;
  }
</style>
