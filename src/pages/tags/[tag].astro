---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostList from '../../components/PostList.astro'
import { tagToSlug } from '../../utils/tagSlug.js'
import { isVisible } from '../../utils/postVisibility.js'

type Props = {
  displayName: string
  tagPage: CollectionEntry<'tagPages'> | undefined
}

export async function getStaticPaths() {
  const allPosts = await getCollection('posts')
  const publishedPosts = allPosts.filter(isVisible)
  const allTagPages = await getCollection('tagPages')
  const tagPageMap = new Map(allTagPages.map(p => [p.id, p]))

  const tagMap = new Map<string, string>() // slug → first-seen display name
  for (const post of publishedPosts) {
    for (const tag of post.data.tags ?? []) {
      const slug = tagToSlug(tag)
      if (!tagMap.has(slug)) tagMap.set(slug, tag)
    }
  }

  return Array.from(tagMap.entries()).map(([slug, displayName]) => ({
    params: { tag: slug },
    props: { displayName, tagPage: tagPageMap.get(slug) },
  }))
}

const { tag } = Astro.params
const { displayName, tagPage } = Astro.props
const permalink = `${Astro.site}tags/${tag}/`
const pageTitle = tagPage?.data.title ?? `posts tagged: ${displayName}`

let TagContent = null
if (tagPage) {
  const { Content } = await render(tagPage)
  TagContent = Content
}

const allPosts = await getCollection('posts')
const taggedPosts = allPosts
  .filter(p => isVisible(p) && p.data.tags?.some(t => tagToSlug(t) === tag))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
---

<BaseLayout title={pageTitle} permalink={permalink} image={tagPage?.data.thumbnail}>
  <div class="container">
    <article class="content">
      <h1 aria-label={tagPage ? undefined : `Posts tagged "${displayName}"`}>{pageTitle}</h1>
      {TagContent && <TagContent />}
    </article>
    {!TagContent && <p>{taggedPosts.length} post{taggedPosts.length === 1 ? '' : 's'}</p>}
    <PostList posts={taggedPosts} />
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25em;
  }
</style>
