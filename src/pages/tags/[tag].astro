---
import { getCollection, getEntry, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tagToSlug } from '../../utils/tagSlug.js'

export async function getStaticPaths() {
  const allPosts = await getCollection('posts')
  const publishedPosts = allPosts.filter(p => !p.data.draft)

  const tagMap = new Map() // slug → first-seen display name
  for (const post of publishedPosts) {
    for (const tag of post.data.tags ?? []) {
      const slug = tagToSlug(tag)
      if (!tagMap.has(slug)) tagMap.set(slug, tag)
    }
  }

  return Array.from(tagMap.entries()).map(([slug, displayName]) => ({
    params: { tag: slug },
    props: { displayName },
  }))
}

const { tag } = Astro.params
const { displayName } = Astro.props
const permalink = `${Astro.site}tags/${tag}/`

const tagPage = await getEntry('tagPages', tag)
const pageTitle = tagPage?.data.title ?? `posts tagged: ${displayName}`

let TagContent = null
if (tagPage) {
  const { Content } = await render(tagPage)
  TagContent = Content
}

const allPosts = await getCollection('posts')
const taggedPosts = allPosts
  .filter(p => !p.data.draft && p.data.tags?.some(t => tagToSlug(t) === tag))
  .sort((a, b) => new Date(b.data.publishDate) - new Date(a.data.publishDate))
---

<BaseLayout title={pageTitle} permalink={permalink}>
  <div class="container">
    <article class="content">
      <h1 aria-label={tagPage ? undefined : `Posts tagged "${displayName}"`}>{pageTitle}</h1>
      {TagContent && <TagContent />}
    </article>
    {!TagContent && <p>{taggedPosts.length} post{taggedPosts.length === 1 ? '' : 's'}</p>}
    <ul class="post-list">
      {taggedPosts.map(post => (
        <li>
          <span class="date">{post.data.publishDate}</span>
          <a href={`/${post.data.slug}/`}>{post.data.title}</a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25em;
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list li {
    display: flex;
    gap: 1em;
    margin: 0.6em 0;
    align-items: baseline;
  }

  .date {
    color: var(--text-secondary);
    font-family: var(--font-family-sans);
    font-size: 0.85em;
    white-space: nowrap;
  }
</style>
