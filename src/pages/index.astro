---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { tagToSlug } from '../utils/tagSlug.js'

const PINNED_SLUGS = [
  '2016/11/17/dont-be-scared-of-merge-conflicts',
  '2023/05/11/recursive-techdebt-upgrade-ticket',
  '2022/03/09/removing-webpage-components',
  '2023/01/30/new-git-repo-with-history-of-old-repo',
]

const title = `Alexander's blog`
const description = 'notes to myself, mostly'
const permalink = Astro.site.href

const allPosts = await getCollection('posts')
const publishedPosts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.publishDate) - new Date(a.data.publishDate))

const pinnedSet = new Set(PINNED_SLUGS)
const pinnedPosts = PINNED_SLUGS
  .map(slug => publishedPosts.find(p => p.data.slug === slug))
  .filter(Boolean)
const chronoPosts = publishedPosts.filter(p => !pinnedSet.has(p.data.slug))
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="container">

    <section class="pinned" aria-label="Pinned posts">
      <h2 class="section-heading">pinned</h2>
      <ul class="post-list">
        {pinnedPosts.map(post => (
          <li>
            <span class="date">{post.data.publishDate}</span>
            <div class="post-content">
              <a href={`/${post.data.slug}/`}>{post.data.title}</a>
              {post.data.tags && post.data.tags.length > 0 && (
                <span class="tags" aria-label="tags">
                  {post.data.tags.map(tag => (
                    <a href={`/tags/${tagToSlug(tag)}/`} class="tag-link" title={`Posts tagged "${tag}"`}>#{tag}</a>
                  ))}
                </span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section aria-label="All posts">
      <h2 class="section-heading">all posts</h2>
      <ul class="post-list">
        {chronoPosts.map(post => (
          <li>
            <span class="date">{post.data.publishDate}</span>
            <div class="post-content">
              <a href={`/${post.data.slug}/`}>{post.data.title}</a>
              {post.data.tags && post.data.tags.length > 0 && (
                <span class="tags" aria-label="tags">
                  {post.data.tags.map(tag => (
                    <a href={`/tags/${tagToSlug(tag)}/`} class="tag-link" title={`Posts tagged "${tag}"`}>#{tag}</a>
                  ))}
                </span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
  .pages-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em 1.2em;
    margin-bottom: 2.5em;
    font-family: var(--font-family-sans);
    font-size: 0.9em;
  }

  .pages-nav a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .pages-nav a:hover {
    color: var(--primary-color);
    text-decoration: underline;
  }

  .section-heading {
    font-family: var(--font-family-sans);
    font-size: 0.75em;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin: 0 0 0.75em;
  }

  .pinned {
    margin-bottom: 2.5em;
    padding: 0.75em 1.25em 1.25em;
    border: 1px solid rgba(84, 142, 155, 0.35);
    border-radius: 6px;
    background-color: rgba(84, 142, 155, 0.06);
  }

  .pinned .post-list li {
    grid-template-columns: 1em 1fr;
  }

  .pinned .post-list .date {
    display: none;
  }

  .pinned .post-list li::before {
    content: "📌";
    font-size: 0.8em;
    align-self: baseline;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list li {
    display: grid;
    grid-template-columns: min-content 1fr;
    column-gap: 1em;
    align-items: baseline;
    margin: 0.75em 0;
  }

  .date {
    color: var(--text-secondary);
    font-family: var(--font-family-sans);
    font-size: 0.8em;
    white-space: nowrap;
  }

  .post-content {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2em 0.75em;
  }

  .post-content > a {
    color: inherit;
    text-decoration: none;
  }

  .post-content > a:hover {
    text-decoration: underline;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2em 0.5em;
    font-size: 0.8em;
  }

</style>
