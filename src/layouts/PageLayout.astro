---
import { getImage } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import BaseLayout from './BaseLayout.astro';

type Props = {
  frontmatter?: {
    title?: string
    description?: string
    slug?: string
    thumbnail?: string
  }
}

const pageImages = import.meta.glob<ImageMetadata>('/src/pages/**/*.{png,jpg,jpeg,webp,gif,avif}', { eager: true, import: 'default' })

const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? '';
const description = frontmatter?.description;
const slug = frontmatter?.slug ?? Astro.url.pathname.replace(/^\/|\/$/g, '');
const permalink = `${Astro.site}${slug}`;

const thumbnailRelPath = frontmatter?.thumbnail
const pageDirPath = '/src/pages' + Astro.url.pathname.replace(/\/$/, '')
const thumbnailKey = thumbnailRelPath ? `${pageDirPath}/${thumbnailRelPath.replace(/^\.\//, '')}` : null
const thumbnailSrc = thumbnailKey ? pageImages[thumbnailKey] : null
const thumbnailImage = thumbnailSrc ? await getImage({ src: thumbnailSrc, format: 'jpeg' }) : null
const socialImage = thumbnailImage ? new URL(thumbnailImage.src, Astro.site).href : undefined
---

<BaseLayout title={title} description={description} permalink={permalink} image={socialImage}>
  <div class="container">
    <article class="content">
      {title && <h1>{title}</h1>}
      <slot />
    </article>
  </div>
</BaseLayout>
