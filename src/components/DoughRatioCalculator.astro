<noscript>The interactivity below requires client-side JavaScript. Not common for me, I know, but that's all I've got for readable content in this blog post!</noscript>

<div id="dough-ratio-calculator">
  <ul>
    <li><input id="drc-starter" type="number" value="66.6" /> starter</li>
    <li><input id="drc-water"   type="number" value="300"  /> water</li>
    <li><input id="drc-flour"   type="number" value="400"  /> flour</li>
    <li><input id="drc-salt"    type="number" value="9"    /> salt</li>
    <li><input id="drc-yeast"   type="number" value="0.5"  /> yeast</li>
  </ul>

  <table>
    <caption>Baker's Percentages</caption>
    <tbody>
      <tr><td>starter:</td><td id="drc-out-starter"></td></tr>
      <tr><td>water:</td>  <td id="drc-out-water"></td></tr>
      <tr><td>flour:</td>  <td>100% always</td></tr>
      <tr><td>salt:</td>   <td id="drc-out-salt"></td></tr>
      <tr><td>yeast:</td>  <td id="drc-out-yeast"></td></tr>
    </tbody>
  </table>

  <p>
    <caption>ratios by starter</caption><br/>
    <abbr title="starter">1</abbr>
    : <abbr title="water"  id="drc-ratio-water"></abbr>
    : <abbr title="flour"  id="drc-ratio-flour"></abbr>
    : <abbr title="salt"   id="drc-ratio-salt"></abbr>
    : <abbr title="yeast"  id="drc-ratio-yeast"></abbr>
  </p>
</div>

<script>
  function sig2(n) { return n.toPrecision(2) }
  function pct(n)  { return (n * 100).toPrecision(3) + '%' }

  function update() {
    const S = parseFloat(document.getElementById('drc-starter').value) || 0
    const W = parseFloat(document.getElementById('drc-water').value)   || 0
    const F = parseFloat(document.getElementById('drc-flour').value)   || 0
    const T = parseFloat(document.getElementById('drc-salt').value)    || 0
    const Y = parseFloat(document.getElementById('drc-yeast').value)   || 0

    document.getElementById('drc-out-starter').textContent = pct(S / F)
    document.getElementById('drc-out-water').textContent   = pct(W / F)
    document.getElementById('drc-out-salt').textContent    = T ? pct(T / F) : 'n/a'
    document.getElementById('drc-out-yeast').textContent   = Y ? pct(Y / F) : 'n/a'

    document.getElementById('drc-ratio-water').textContent = sig2(W / S)
    document.getElementById('drc-ratio-flour').textContent = sig2(F / S)
    document.getElementById('drc-ratio-salt').textContent  = T ? pct(T / S) : 'n/a'
    document.getElementById('drc-ratio-yeast').textContent = Y ? pct(Y / S) : 'n/a'
  }

  document.getElementById('dough-ratio-calculator').addEventListener('input', update)
  update()
</script>
