<div class="theme-toggle">
  <label>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
    </svg>
    <input type="radio" name="theme-toggle" value="light" title="Use light theme" aria-label="Use light theme" />
  </label>
  <label>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
    </svg>
    <input type="radio" name="theme-toggle" value="dark" title="Use dark theme" aria-label="Use dark theme" />
  </label>
</div>

<script>
  function applyTheme(theme) {
    const root = document.documentElement;
    const lightLabel = document.querySelector('input[aria-label="Use light theme"]')?.parentElement;
    const darkLabel = document.querySelector('input[aria-label="Use dark theme"]')?.parentElement;
    const lightInput = document.querySelector('input[aria-label="Use light theme"]');
    const darkInput = document.querySelector('input[aria-label="Use dark theme"]');

    if (theme === 'dark') {
      root.classList.add('theme-dark');
      darkLabel?.classList.add('checked');
      lightLabel?.classList.remove('checked');
      if (darkInput) darkInput.checked = true;
    } else {
      root.classList.remove('theme-dark');
      lightLabel?.classList.add('checked');
      darkLabel?.classList.remove('checked');
      if (lightInput) lightInput.checked = true;
    }
  }

  function initThemeToggle() {
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      applyTheme('dark');
    } else {
      applyTheme('light');
    }
  }

  document.addEventListener('change', (event) => {
    const target = event.target;
    if (target instanceof HTMLInputElement && target.name === 'theme-toggle') {
      localStorage.setItem('theme', target.value);
      applyTheme(target.value);
    }
  });

  document.addEventListener('astro:page-load', initThemeToggle);
  initThemeToggle();
</script>
